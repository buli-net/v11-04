<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:id="@+id/paper_wallet_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_warning"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_address_label"
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:textColor="?android:attr/textColorPrimary" />

        <ImageView
            android:id="@+id/paper_wallet_qr_address"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:background="#ffffff"
            android:padding="8dp" />

        <TextView
            android:id="@+id/paper_wallet_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textIsSelectable="true"
            android:textColor="?android:attr/textColorPrimary"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/paper_wallet_address_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="?android:attr/textColorSecondary"
            android:paddingTop="4dp"
            android:clickable="true"
            android:focusable="true"
            android:text="SegWit bech32" />

        <Button
            android:id="@+id/paper_wallet_copy_address"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_copy" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_pubkey_label"
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/paper_wallet_pubkey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textIsSelectable="true"
            android:textColor="?android:attr/textColorPrimary"
            android:textAppearance="?android:attr/textAppearanceSmall" />

        <Button
            android:id="@+id/paper_wallet_copy_pubkey"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_copy" />

        <TextView
            android:id="@+id/paper_wallet_key_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_key_label"
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginTop="12dp" />

        <ImageView
            android:id="@+id/paper_wallet_qr_key"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:background="#ffffff"
            android:padding="8dp" />

        <TextView
            android:id="@+id/paper_wallet_key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textIsSelectable="true"
            android:textColor="?android:attr/textColorPrimary"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/paper_wallet_copy_privkey"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/paper_wallet_copy" />

            <Button
                android:id="@+id/paper_wallet_privkey_format"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="WIF" />

            <Button
                android:id="@+id/paper_wallet_toggle_key"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/paper_wallet_hide_key" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/paper_wallet_generate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_generate_new" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/paper_wallet_save"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/paper_wallet_save" />

            <Button
                android:id="@+id/paper_wallet_share"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/paper_wallet_share" />

            <Button
                android:id="@+id/paper_wallet_print"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/paper_wallet_print" />
        </LinearLayout>

        <Button
            android:id="@+id/paper_wallet_export_txt"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Export TXT" />

    </LinearLayout>
</ScrollView>
